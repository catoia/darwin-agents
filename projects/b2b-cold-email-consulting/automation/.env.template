# B2B Cold Email Automation - API Keys Configuration
# Copy this file to .env and fill in your actual API keys

# ============================================================
# REQUIRED API KEYS
# ============================================================

# SendGrid (for sending emails)
# Get it: https://sendgrid.com/ → Settings → API Keys → Create API Key
# Free tier: 100 emails/day
export SENDGRID_API_KEY="YOUR_SENDGRID_API_KEY_HERE"

# OpenAI (for AI-powered email personalization)
# Get it: https://platform.openai.com/ → API Keys → Create new secret key
# Cost: ~$0.02 per email with GPT-4
export OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"

# ============================================================
# OPTIONAL API KEYS (improve prospect finding)
# ============================================================

# Apollo.io (for finding B2B SaaS founders)
# Get it: https://apollo.io/ → Settings → API → Copy API key
# Free tier: 50 contacts/month
export APOLLO_API_KEY="YOUR_APOLLO_API_KEY_HERE"

# Hunter.io (for email enrichment/verification)
# Get it: https://hunter.io/ → API → Copy API key
# Free tier: 50 searches/month
export HUNTER_API_KEY="YOUR_HUNTER_API_KEY_HERE"

# ============================================================
# USAGE
# ============================================================
# After filling in the keys:
# 1. source automation/.env
# 2. python3 automation/orchestrator.py initial 20
