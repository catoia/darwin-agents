# Darwin Agents — environment variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Cloudflare (required for traffic metrics + deploys) ──────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Revenue sources (pick at least one, or leave blank for manual entry) ─────

# Google AdSense
ADSENSE_ACCESS_TOKEN=
ADSENSE_ACCOUNT_ID=

# Stripe (for micro-SaaS / one-time payments)
STRIPE_API_KEY=
